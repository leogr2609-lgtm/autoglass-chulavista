---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ServiceBlock from '../components/ServiceBlock.astro';
import CtaBlock from '../components/CtaBlock.astro';
import ContactBlock from '../components/ContactBlock.astro';
import StickyCallBar from '../components/StickyCallBar.astro';
import Footer from '../components/Footer.astro';
import { serviceAreas } from '../data/serviceAreas';
import { business, coreServices } from '../data/business';

const homeSchemas = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    serviceType: "Mobile Auto Glass Service",
    provider: {
      "@type": "AutoRepair",
      name: business.name,
      telephone: business.phoneE164
    },
    areaServed: serviceAreas.map((area) => ({
      "@type": "City",
      name: area.city
    })),
    hasOfferCatalog: {
      "@type": "OfferCatalog",
      name: "Auto Glass Services",
      itemListElement: coreServices.map((service) => ({
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: service
        }
      }))
    }
  }
];

const services = [
  {
    title: "Windshield Replacement",
    description: "Professional windshield replacement with high-quality glass. In shop or at your location.",
    image: "/wr-black-car.webp",
    images: ["/wr-green-suv.webp", "/wr-jeep.webp"],
    highlights: ["OEM-equivalent glass", "Work and parts guaranteed"],
    details: [
      "Full removal and professional reinstallation",
      "Factory-quality fit with OEM-equivalent glass",
      "Ready to drive as soon as service is complete",
      "Includes seal and molding inspection"
    ]
  },
  {
    title: "Windshield Rock Chip Repair",
    description: "Quick repairs to stop chips and cracks before they spread.",
    image: "/rc-chip-closeup.webp",
    images: ["/rc-chip-interior.webp", "/rc-chip-bullseye.webp"],
    highlights: ["Stops cracks from spreading", "In shop and mobile service"],
    details: [
      "Resin injection to restore structural integrity",
      "Best results when repaired within 48 hours",
      "Maintains windshield structural integrity",
      "All work and parts guaranteed"
    ]
  },
  {
    title: "Door Glass Replacement",
    description: "Shattered side window? We clean up and install a new one on site or at our shop.",
    image: "/door-glass-replacement.webp",
    images: ["/dg-quarter-glass.webp"],
    highlights: ["Tempered safety glass", "Work and parts guaranteed"],
    details: [
      "Complete side window removal and glass cleanup",
      "Tempered safety glass for all vehicle models",
      "In shop and mobile service available",
      "Includes weatherstrip and seal check"
    ]
  },
  {
    title: "Window Regulator Repair",
    description: "Window stuck or won't roll up? We fix motors and regulators.",
    image: "/window-regulator-repair.webp",
    images: ["/wr-regulator-part.webp"],
    highlights: ["On-site diagnosis", "Parts sourced same-day"],
    details: [
      "Motor and regulator diagnosis on site",
      "Electrical and manual systems supported",
      "Parts sourced same-day when possible",
      "Fully tested before job completion"
    ]
  },
  {
    title: "Back Glass Replacement",
    description: "Complete rear windshield replacement for all vehicle types.",
    image: "/back-glass-replacement.webp",
    images: ["/bg-pickup-red.webp"],
    highlights: ["Laminated safety glass option", "All vehicle types"],
    details: [
      "Complete rear windshield replacement",
      "Laminated safety glass available as an option",
      "Includes trim and seal replacement",
      "All work and parts guaranteed"
    ]
  },
  {
    title: "Leak and Molding Repair",
    description: "Sealing leaks and securing loose molding to protect your interior.",
    image: "/windshield-leak-molding-repair.webp",
    highlights: ["Water test diagnosis", "All work guaranteed"],
    details: [
      "Pinpoint leak source with water testing",
      "Replace worn molding and rubber seals",
      "Prevents interior water damage",
      "All work and parts guaranteed"
    ]
  }
];

const reviews = [
  {
    text: "He came to where I was and got my windshield changed in no time. Clean job. Recommend!",
    name: "Monica Fregoso"
  },
  {
    text: "Great work, efficient and fast. The service was really great and the repair was pretty quick and very high quality.",
    name: "Irene Haidee Medina Navarro"
  },
  {
    text: "Great customer service, friendly, did a great job. I will be coming back! Thank you!",
    name: "Liz Yarah"
  }
];

const whyChooseUs = [
  {
    title: "Same-Day Service",
    description: "Most jobs completed the same day you call."
  },
  {
    title: "In Shop and Mobile",
    description: "Visit our shop or we come to your home, work, or wherever you are."
  },
  {
    title: "Work and Parts Guaranteed",
    description: "All labor and parts backed by our warranty for your peace of mind."
  },
  {
    title: "Free Phone Quotes",
    description: "Call us for a no-obligation estimate. Honest pricing upfront."
  }
];

const coverageAreas = serviceAreas;
---

<Layout
  title="Auto Glass Chula Vista CA | Mobile Windshield Replacement and Repair"
  description="Mobile auto glass service in Chula Vista and nearby South San Diego County. Windshield replacement, rock chip repair, door glass, back glass, and regulator repair."
  canonicalUrl={business.siteDomain}
  structuredData={homeSchemas}
>
  <Header phone={business.phoneDisplay} />

  <main>
    <Hero
      headline="In Shop or Mobile Auto Glass Service in Chula Vista Serving All San Diego CA"
      subheadline="Fast, reliable auto glass repair and replacement - at our shop or your location. Cracked windshields, broken door glass, and stuck windows. Get back on the road safely today."
      phone={business.phoneDisplay}
    />

    <section id="services" class="py-16 md:py-24 bg-ui-alt">
      <div class="max-w-[1200px] mx-auto px-4 md:px-8">
        <div class="section-heading">
          <h2>Our Auto Glass Services</h2>
          <p>We handle common vehicle glass issues at our shop or directly at your location across South San Diego County.</p>
          <div class="inline-flex items-center gap-2 mt-4 text-[#0a2540] text-sm font-semibold tracking-wide">
            <svg class="w-4 h-4 text-action" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            In Shop and Mobile Service - We Come to You or Visit Our Shop
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
          {services.map((service) => (
            <ServiceBlock
              title={service.title}
              description={service.description}
              image={service.image}
              images={service.images}
              highlights={service.highlights}
              details={service.details}
              phone={business.phoneDisplay}
            />
          ))}
        </div>
      </div>
    </section>

    <section class="py-16 md:py-24 bg-white border-y border-ui-border">
      <div class="max-w-[1200px] mx-auto px-4 md:px-8">
        <div class="section-heading">
          <h2>Why Choose Us</h2>
          <p>Local professionals you can count on for quality auto glass service.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-10 gap-y-14">
          {whyChooseUs.map((item, index) => (
            <div class="group relative pl-16">
              <div class="absolute left-0 top-0 text-5xl font-black text-primary/30 group-hover:text-action transition-colors duration-300 leading-none">
                0{index + 1}
              </div>
              <h3 class="text-[22px] font-extrabold mb-3 text-[#0f172a] uppercase tracking-wide">{item.title}</h3>
              <p class="text-[15px] leading-relaxed" style="color: #475569;">{item.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CtaBlock
      headline="Don't let a cracked windshield get worse."
      subheadline="Visit our shop or we come to you anywhere in South San Diego County."
      phone={business.phoneDisplay}
    />

    <section class="py-16 md:py-24 bg-ui-alt">
      <div class="max-w-[1200px] mx-auto px-4 md:px-8">
        <div class="section-heading">
          <h2>What Our Customers Say</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
          {reviews.map((review) => (
            <div class="card p-7 md:p-8 border-l-4 border-l-primary relative">
              <div class="absolute top-4 right-6 text-6xl font-serif text-primary/10 leading-none select-none">"</div>
              <div class="flex gap-0.5 mb-4">
                {[...Array(5)].map(() => (
                  <svg class="w-5 h-5 text-star" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                ))}
              </div>
              <p class="italic text-ui-text-muted mb-5 text-[15px] leading-relaxed relative z-10">"{review.text}"</p>
              <p class="font-semibold text-sm text-ui-text-main">- {review.name}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="py-12 md:py-16 bg-white border-y border-ui-border">
      <div class="max-w-[1200px] mx-auto px-4 md:px-8 text-center">
        <div class="flex items-center justify-center gap-2.5 mb-6">
          <div class="w-8 h-8 bg-primary-light text-primary rounded-lg flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h3 class="text-xl font-bold">Areas We Serve in South San Diego County</h3>
        </div>
        <div class="flex flex-wrap justify-center gap-3">
          {coverageAreas.map((area) => (
            <a
              href={`/auto-glass/${area.slug}`}
              class="px-4 py-2 bg-ui-alt border border-ui-border rounded-full text-sm font-medium text-ui-text-muted hover:border-primary/40 hover:text-primary transition-colors duration-200"
            >
              {area.city}, CA
            </a>
          ))}
        </div>
      </div>
    </section>

    <ContactBlock phone={business.phoneDisplay} address={business.address} />
  </main>

  <Footer businessName={business.legalName} phone={business.phoneDisplay} address={business.address} />
  <StickyCallBar phone={business.phoneDisplay} />
</Layout>

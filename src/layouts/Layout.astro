---
import '../styles/global.css';
import { business } from '../data/business';

interface Props {
	title: string;
	description?: string;
	canonicalUrl?: string;
	ogImage?: string;
	structuredData?: Record<string, unknown>[];
}

const { 
	title, 
	description = "Auto Glass Mobile Service in Chula Vista CA. Professional windshield replacement, rock chip repair, and mobile auto glass service across South San Diego County. Call +1 (760) 880-0711.",
	canonicalUrl = business.siteDomain,
	ogImage = `${business.siteDomain}${business.ogImage}`,
	structuredData = []
} = Astro.props;

const baseSchemas = [
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		"name": business.name,
		"url": business.siteDomain
	},
	{
		"@context": "https://schema.org",
		"@type": "AutoRepair",
		"name": business.name,
		"description": "Professional mobile auto glass repair and windshield replacement service in Chula Vista and South San Diego County.",
		"url": business.siteDomain,
		"telephone": business.phoneE164,
		"email": business.email,
		"address": {
			"@type": "PostalAddress",
			"streetAddress": "1165 Third Ave",
			"addressLocality": "Chula Vista",
			"addressRegion": "CA",
			"postalCode": "91911",
			"addressCountry": "US"
		},
		"geo": {
			"@type": "GeoCoordinates",
			"latitude": 32.6401,
			"longitude": -117.0842
		},
		"areaServed": [
			{ "@type": "City", "name": "Chula Vista" },
			{ "@type": "City", "name": "National City" },
			{ "@type": "City", "name": "Bonita" },
			{ "@type": "City", "name": "Imperial Beach" },
			{ "@type": "City", "name": "San Ysidro" },
			{ "@type": "City", "name": "Spring Valley" }
		],
		"openingHoursSpecification": [
			{
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
				"opens": "07:00",
				"closes": "18:00"
			},
			{
				"@type": "OpeningHoursSpecification",
				"dayOfWeek": "Saturday",
				"opens": "07:00",
				"closes": "14:00"
			}
		],
		"priceRange": "$$",
		"image": `${business.siteDomain}${business.ogImage}`,
		"sameAs": []
	}
];

const allSchemas = [...baseSchemas, ...structuredData];
---

<!doctype html>
<html lang="en">
	<head>
		<!-- Google Tag Manager -->
		<script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
		new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
		j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
		'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
		})(window,document,'script','dataLayer','GTM-KM5MF8VF');</script>
		<!-- End Google Tag Manager -->

		<!-- Google tag (gtag.js) - Google Ads -->
		<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=AW-17960207893"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'AW-17960207893');
			gtag('config', 'AW-17960207893/BMvLCNu485ccEJWMjPRC', {
				'phone_conversion_number': '(760) 880-0711'
			});
		</script>

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		
		<!-- Favicon -->
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		
		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<link rel="canonical" href={canonicalUrl} />
		
		<!-- Geographic Meta (Local SEO) -->
		<meta name="geo.region" content="US-CA" />
		<meta name="geo.placename" content="Chula Vista" />
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:locale" content="en_US" />
		<meta property="og:site_name" content="Auto Glass Mobile Service" />
		
		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		
		<!-- Preconnect for performance -->
		<link rel="preconnect" href="https://www.googletagmanager.com" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		
		{allSchemas.map((schema) => (
			<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		))}

		<meta name="generator" content={Astro.generator} />
	</head>
	<body class="bg-ui-base">
		<!-- Google Tag Manager (noscript) -->
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KM5MF8VF"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- End Google Tag Manager (noscript) -->
		<slot />
	</body>
</html>

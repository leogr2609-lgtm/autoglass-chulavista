---
interface Props {
  phone: string;
}
const { phone } = Astro.props;
const phoneTel = `tel:${phone.replace(/\D/g, '')}`;
---
<div class="md:hidden fixed bottom-0 left-0 right-0 p-3 bg-white/95 backdrop-blur-sm border-t border-ui-border shadow-[0_-4px_12px_rgba(0,0,0,0.1)] z-50">
  <a href={phoneTel} class="w-full bg-action hover:bg-action-hover text-white flex items-center justify-center gap-2.5 py-3.5 px-4 rounded-xl font-bold text-lg transition-all duration-200 shadow-[0_2px_8px_rgba(230,57,70,0.3)]">
    <span class="relative flex h-3 w-3">
      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white/60 opacity-75"></span>
      <span class="relative inline-flex rounded-full h-3 w-3 bg-white/90"></span>
    </span>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
    Call {phone}
  </a>
</div>
<!-- Padding block to prevent content from hiding behind the sticky bar on mobile -->
<div class="h-20 md:hidden w-full"></div>

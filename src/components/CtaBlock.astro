---
interface Props {
  headline: string;
  subheadline?: string;
  phone: string;
}
const { headline, subheadline, phone } = Astro.props;
const phoneTel = `tel:${phone.replace(/\D/g, '')}`;
---
<section class="relative bg-[#0a2540] text-white py-16 md:py-24 overflow-hidden">
  <!-- Subtle Pattern -->
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"></div>

  <div class="max-w-[1200px] mx-auto px-4 md:px-8 text-center flex flex-col items-center relative z-10">
    <h2 class="text-3xl md:text-4xl lg:text-[42px] font-bold text-white mb-4 max-w-2xl leading-tight">{headline}</h2>
    {subheadline && (
      <p class="text-base font-medium mb-2 max-w-lg" style="color: rgba(255,255,255,0.85);">{subheadline}</p>
    )}
    <p class="text-lg mb-8 max-w-lg" style="color: rgba(255,255,255,0.65);">Call now for a free estimate. We come to your location across South San Diego County.</p>
    <a href={phoneTel} class="btn btn-primary btn-lg gap-3 text-xl mt-2 shadow-[0_4px_20px_rgba(230,57,70,0.45)]">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
      Call {phone}
    </a>
  </div>
</section>

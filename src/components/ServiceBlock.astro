---
interface Props {
  title: string;
  description: string;
  image: string;
  images?: string[];
  highlights?: string[];
  details?: string[];
  phone: string;
}
const { title, description, image, images = [], highlights = [], details = [], phone } = Astro.props;
const phoneTel = `tel:${phone.replace(/\D/g, '')}`;
const cardId = title.toLowerCase().replace(/[^a-z0-9]/g, '-');
// Build the full image list: primary image + additional images
const allImages = [image, ...images];
const hasCarousel = allImages.length > 1;
---
<div class="service-card card flex flex-col h-full bg-white overflow-hidden group" id={`card-${cardId}`}>
  <!-- Service Image with Brand Treatment -->
  <div class="w-full aspect-[4/3] relative overflow-hidden">
    {hasCarousel ? (
      <div class="carousel-container" data-carousel>
        {allImages.map((img, i) => (
          <img
            src={img}
            alt={`${title} - Image ${i + 1}`}
            loading={i === 0 ? "eager" : "lazy"}
            class:list={["service-img carousel-slide", { "is-active": i === 0 }]}
            data-slide={i}
            data-full-src={img}
          />
        ))}
        <!-- Nav Arrows -->
        <button type="button" class="carousel-arrow carousel-prev" data-dir="prev" aria-label="Previous image">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button type="button" class="carousel-arrow carousel-next" data-dir="next" aria-label="Next image">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </button>
        <!-- Carousel Indicators -->
        <div class="carousel-indicators">
          {allImages.map((_, i) => (
            <button type="button" class:list={["carousel-dot", { "is-active": i === 0 }]} data-dot={i} aria-label={`Go to image ${i + 1}`}></button>
          ))}
        </div>
      </div>
    ) : (
      <img
        src={image}
        alt={title}
        loading="lazy"
        class="service-img"
        data-full-src={image}
      />
    )}
    <div class="service-overlay"></div>
    <!-- Zoom icon hint -->
    <div class="zoom-hint">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
    </div>
  </div>
  
  <div class="service-body p-7 md:p-9 flex flex-col flex-grow">
    <!-- Title -->
    <h3 class="text-[22px] md:text-[26px] font-extrabold mb-3 text-[#0f172a] leading-tight group-hover:text-primary transition-colors">{title}</h3>
    
    <!-- Description -->
    <p class="text-[15px] leading-relaxed mb-4" style="color: #475569;">{description}</p>

    <!-- Always-visible highlights -->
    {highlights.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-5">
        {highlights.map(h => (
          <span class="inline-flex items-center gap-1.5 text-[13px] font-medium px-3 py-1.5 rounded-full bg-[#eef4ff] border border-[#dbeafe]" style="color: #1e40af;">
            <svg class="w-3.5 h-3.5 text-green-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
            {h}
          </span>
        ))}
      </div>
    )}

    <!-- Spacer to push Learn More + Button to bottom -->
    <div class="flex-grow"></div>

    <!-- Expandable Details -->
    {details.length > 0 && (
      <div class="mb-5">
        <button
          type="button"
          class="service-toggle inline-flex items-center gap-2 text-[#0a2540] text-[13px] font-bold uppercase tracking-wider hover:text-primary transition-colors cursor-pointer bg-transparent border-none p-0"
          data-target={`details-${cardId}`}
          aria-expanded="false"
        >
          <span class="toggle-text">Learn More</span>
          <svg class="toggle-icon w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
        
        <div id={`details-${cardId}`} class="service-details">
          <ul class="mt-4 space-y-2.5 pt-4 border-t border-gray-100">
            {details.map(detail => (
              <li class="flex items-start gap-2.5 text-[14px] leading-snug" style="color: #334155;">
                <svg class="w-4 h-4 text-green-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                </svg>
                {detail}
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}
    
    <!-- CTA Button — always at bottom -->
    <a href={phoneTel} class="btn btn-primary w-full py-3.5 text-sm md:text-base">
      Schedule Service
    </a>
  </div>
</div>

<!-- Lightbox (one per card, rendered in place) -->
<div class="lightbox-overlay" data-lightbox-for={`card-${cardId}`}>
  <button type="button" class="lightbox-close" aria-label="Close">&times;</button>
  <img class="lightbox-img" src="" alt="" />
  {hasCarousel && (
    <>
      <button type="button" class="lightbox-arrow lightbox-prev" data-ldir="prev" aria-label="Previous">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      </button>
      <button type="button" class="lightbox-arrow lightbox-next" data-ldir="next" aria-label="Next">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      </button>
    </>
  )}
</div>

<style>
  .service-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(30%) brightness(0.95);
    transform: scale(1.05);
    transition: all 0.5s ease-out;
    cursor: pointer;
  }

  .service-card:hover .service-img {
    filter: grayscale(0%) brightness(1);
    transform: scale(1.15);
  }

  .service-overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(10, 37, 64, 0.35);
    transition: all 0.5s ease-out;
    z-index: 2;
    pointer-events: none;
  }

  .service-card:hover .service-overlay {
    background-color: rgba(10, 37, 64, 0.1);
  }

  /* Zoom hint */
  .zoom-hint {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 4;
    background: rgba(0,0,0,0.4);
    color: white;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .service-card:hover .zoom-hint {
    opacity: 1;
  }

  /* Carousel */
  .carousel-container {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.8s ease-in-out;
    z-index: 0;
  }

  .carousel-slide.is-active {
    opacity: 1;
    z-index: 1;
  }

  /* Arrows */
  .carousel-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 5;
    background: rgba(0,0,0,0.35);
    backdrop-filter: blur(4px);
    color: white;
    border: none;
    border-radius: 50%;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.3s ease, background 0.2s ease;
  }

  .carousel-arrow:hover {
    background: rgba(0,0,0,0.6);
  }

  .service-card:hover .carousel-arrow {
    opacity: 1;
  }

  .carousel-prev { left: 8px; }
  .carousel-next { right: 8px; }

  .carousel-indicators {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 5;
  }

  .carousel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    border: none;
    padding: 0;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .carousel-dot:hover {
    background: rgba(255, 255, 255, 0.7);
  }

  .carousel-dot.is-active {
    background: rgba(255, 255, 255, 0.95);
    transform: scale(1.3);
  }

  /* Lightbox */
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0,0,0,0.88);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .lightbox-overlay.is-open {
    opacity: 1;
    visibility: visible;
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 85vh;
    object-fit: contain;
    border-radius: 6px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    transition: transform 0.3s ease;
  }

  .lightbox-close {
    position: absolute;
    top: 20px;
    right: 24px;
    z-index: 10;
    background: none;
    border: none;
    color: white;
    font-size: 36px;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity 0.2s ease;
    line-height: 1;
  }

  .lightbox-close:hover {
    opacity: 1;
  }

  .lightbox-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    opacity: 0.7;
    transition: all 0.2s ease;
  }

  .lightbox-arrow:hover {
    opacity: 1;
    background: rgba(255,255,255,0.2);
  }

  .lightbox-prev { left: 20px; }
  .lightbox-next { right: 20px; }

  /* Expandable panel */
  .service-details {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
    opacity: 0;
  }

  .service-details.is-open {
    max-height: 300px;
    opacity: 1;
  }

  .toggle-icon {
    transition: transform 0.3s ease;
  }

  .service-toggle[aria-expanded="true"] .toggle-icon {
    transform: rotate(180deg);
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Toggle details
    document.querySelectorAll('.service-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        const panel = document.getElementById(targetId);
        const textEl = btn.querySelector('.toggle-text');
        const isOpen = panel.classList.contains('is-open');
        
        panel.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', String(!isOpen));
        textEl.textContent = isOpen ? 'Learn More' : 'Show Less';
      });
    });

    // Carousels
    document.querySelectorAll('[data-carousel]').forEach(carousel => {
      const slides = carousel.querySelectorAll('.carousel-slide');
      const dots = carousel.querySelectorAll('.carousel-dot');
      const arrows = carousel.querySelectorAll('.carousel-arrow');
      if (slides.length <= 1) return;

      let current = 0;
      const total = slides.length;
      let autoTimer;

      function goTo(index) {
        slides[current].classList.remove('is-active');
        dots[current].classList.remove('is-active');
        current = ((index % total) + total) % total;
        slides[current].classList.add('is-active');
        dots[current].classList.add('is-active');
      }

      function resetAuto() {
        clearInterval(autoTimer);
        autoTimer = setInterval(() => goTo(current + 1), 4000);
      }

      // Click dots
      dots.forEach(dot => {
        dot.addEventListener('click', (e) => {
          e.stopPropagation();
          goTo(parseInt(dot.getAttribute('data-dot')));
          resetAuto();
        });
      });

      // Click arrows
      arrows.forEach(arrow => {
        arrow.addEventListener('click', (e) => {
          e.stopPropagation();
          goTo(arrow.getAttribute('data-dir') === 'next' ? current + 1 : current - 1);
          resetAuto();
        });
      });

      // Start auto
      resetAuto();

      // Store reference for lightbox
      carousel._goTo = goTo;
      carousel._getCurrent = () => current;
      carousel._getTotal = () => total;
      carousel._getSlides = () => slides;
    });

    // Lightbox
    document.querySelectorAll('.service-card').forEach(card => {
      const cardId = card.id;
      const lightbox = document.querySelector(`[data-lightbox-for="${cardId}"]`);
      if (!lightbox) return;

      const lbImg = lightbox.querySelector('.lightbox-img');
      const lbClose = lightbox.querySelector('.lightbox-close');
      const lbArrows = lightbox.querySelectorAll('.lightbox-arrow');
      const carousel = card.querySelector('[data-carousel]');
      const imageArea = card.querySelector('.aspect-\\[4\\/3\\]');

      // Get all image srcs
      const allSrcs = [];
      if (carousel) {
        carousel.querySelectorAll('.carousel-slide').forEach(s => allSrcs.push(s.getAttribute('data-full-src')));
      } else {
        const singleImg = card.querySelector('.service-img');
        if (singleImg) allSrcs.push(singleImg.getAttribute('data-full-src'));
      }

      let lbIndex = 0;

      function showLightbox(index) {
        lbIndex = ((index % allSrcs.length) + allSrcs.length) % allSrcs.length;
        lbImg.src = allSrcs[lbIndex];
        lbImg.alt = card.querySelector('h3')?.textContent || '';
        lightbox.classList.add('is-open');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        lightbox.classList.remove('is-open');
        document.body.style.overflow = '';
      }

      // Open on image click
      imageArea?.addEventListener('click', (e) => {
        if (e.target.closest('.carousel-arrow') || e.target.closest('.carousel-dot')) return;
        const startIndex = carousel ? parseInt(carousel._getCurrent?.() || 0) : 0;
        showLightbox(startIndex);
      });

      // Close
      lbClose?.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', (e) => {
        if (e.target === lightbox) closeLightbox();
      });

      // Lightbox arrows
      lbArrows.forEach(arrow => {
        arrow.addEventListener('click', (e) => {
          e.stopPropagation();
          showLightbox(arrow.getAttribute('data-ldir') === 'next' ? lbIndex + 1 : lbIndex - 1);
        });
      });

      // Keyboard
      document.addEventListener('keydown', (e) => {
        if (!lightbox.classList.contains('is-open')) return;
        if (e.key === 'Escape') closeLightbox();
        if (e.key === 'ArrowRight') showLightbox(lbIndex + 1);
        if (e.key === 'ArrowLeft') showLightbox(lbIndex - 1);
      });
    });
  });
</script>
